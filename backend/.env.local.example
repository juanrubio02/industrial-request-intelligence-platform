APP_NAME=forgeflow-request-intelligence-platform
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DOCUMENTS_STORAGE_PATH=storage/documents

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=forgeflow_requests
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

AUTH_SECRET_KEY=change-this-auth-secret-in-production
AUTH_TOKEN_TTL_SECONDS=3600
AUTH_SESSION_COOKIE_NAME=iri_session
AUTH_SESSION_COOKIE_SAMESITE=lax
AUTH_SESSION_COOKIE_SECURE=false
